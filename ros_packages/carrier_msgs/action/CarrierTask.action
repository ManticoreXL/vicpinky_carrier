# Goal: 로봇에 보낼 작업 명령
string task_type          # "deliver" | "return" | "dock" | "custom"
string target_id          # 목적지 ID (스테이션, 웨이포인트 등)
float32 timeout_sec       # 최대 허용 시간 (초), 0 이면 무제한
string[] extra_args       # 추가 파라미터 키-값 쌍 ["key=value", ...]
---
# Result
bool success
string message
float32 elapsed_sec
---
# Feedback
string status             # 현재 상태 설명
float32 progress          # 0.0 ~ 1.0
float32 distance_remaining  # 남은 거리 (m), 해당 없으면 -1
